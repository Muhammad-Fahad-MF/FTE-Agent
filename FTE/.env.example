# FTE-Agent Configuration
# Copy this file to .env and adjust values

# Security: Must be "true" to run (prevents accidental production runs)
DEV_MODE=true

# Safety: If "true", logs intended actions without executing
DRY_RUN=true

# Path to Obsidian vault (relative to FTE/)
VAULT_PATH=./vault

# Watcher check interval in seconds (max 60 per constitution)
WATCHER_INTERVAL=60
