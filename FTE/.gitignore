# Environment variables (contains secrets)
.env
.env.local

# Database files (runtime data)
*.db
*.db-journal
*.sqlite
*.sqlite3
data/*.db

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environment
.venv/
venv/

# Logs (contains sensitive data)
Logs/
*.log

# Vault data (user data, not code)
# Keep template files, exclude user-generated content
vault/Inbox/
vault/Needs_Action/
vault/Done/
vault/Pending_Approval/
vault/Approved/
vault/Rejected/
vault/Plans/
vault/Briefings/
vault/Logs/
vault/Failed_Actions/
vault/*.archived

# Templates (keep in version control)
!vault/Templates/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Type checking
.mypy_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo
