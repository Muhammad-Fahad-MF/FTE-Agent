# Environment variables (contains secrets)
.env
.env.local

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environment
.venv/
venv/

# Logs (contains sensitive data)
Logs/
*.log

# Vault data (user data, not code)
# Keep template files, exclude user-generated content
vault/Inbox/
vault/Needs_Action/
vault/Done/
vault/Pending_Approval/
vault/Approved/
vault/Rejected/
vault/Logs/
vault/*.archived

# Testing
.pytest_cache/
.coverage
htmlcov/

# Type checking
.mypy_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo
